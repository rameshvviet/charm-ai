{
  "name": "charm-ai",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@cap-js/sqlite": "^2.4.0",
    "@sap/approuter": "^20.10.0",
    "@sap/cds": "^9.9.1",
    "@sap/cds-compiler": "^6.9.3",
    "@sap/cds-dk": "^9.9.2",
    "@sap/xssec": "^4"
  },
  "scripts": {
    "start": "cds-serve"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": ":memory:"
        }
      },
      "[production]": {
        "auth": "xsuaa"
      }
    }
  },
  "private": true,
  "sapux": [
    "app/admin-authors",
    "app/admin-books",
    "app/browse",
    "app/genres"
  ],
  "devDependencies": {
    "@sap/cds-dk": "^9"
  }
}
